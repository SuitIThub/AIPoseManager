# Copy to .env or set in your MCP host (Cursor / Claude Desktop).
POSE_PLUGIN_URL=http://127.0.0.1:7842
POSE_PLUGIN_TOKEN=paste_token_from_bepinex_log
POSE_STORAGE_DIR=%USERPROFILE%\.studio_pose_bridge
POSE_SCREENSHOT_SIZE=512
POSE_DEFAULT_REGIONS=torso,left_arm,right_arm,left_leg,right_leg
POSE_TIMEOUT=10.0
POSE_SCREENSHOT_TIMEOUT=30.0
POSE_LOG_LEVEL=INFO
